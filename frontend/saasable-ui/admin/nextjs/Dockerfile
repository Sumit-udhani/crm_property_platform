FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install && npm cache clean --force

COPY . .
ARG NEXT_PUBLIC_API_HOST
ARG NEXT_PUBLIC_BUY_URL

ENV NEXT_PUBLIC_API_HOST=$NEXT_PUBLIC_API_HOST
ENV NEXT_PUBLIC_BUY_URL=$NEXT_PUBLIC_BUY_URL

RUN npm run build

ENV HOST=0.0.0.0
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "run", "start"]
generator client {
  provider        = "prisma-client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model account_addresses {
  account_id   BigInt
  address_id   BigInt
  address_type String    @db.VarChar(50)
  accounts     accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  addresses    addresses @relation(fields: [address_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([account_id, address_id, address_type])
}

model account_types {
  id       BigInt     @id @default(autoincrement())
  name     String     @unique @db.VarChar(100)
  accounts accounts[]
}

model accounts {
  id                               BigInt              @id @default(autoincrement())
  branch_id                        BigInt?
  account_type_id                  BigInt
  name                             String              @db.VarChar(150)
  registration_no                  String?             @db.VarChar(100)
  tax_no                           String?             @db.VarChar(100)
  website                          String?             @db.VarChar(255)
  notes                            String?
  created_by                       BigInt?
  updated_by                       BigInt?
  created_at                       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime            @default(now()) @db.Timestamptz(6)
  account_addresses                account_addresses[]
  account_types                    account_types       @relation(fields: [account_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branches                         branches?           @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users_accounts_created_byTousers users?              @relation("accounts_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  users_accounts_updated_byTousers users?              @relation("accounts_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  contacts                         contacts[]
  invoices                         invoices[]
  lead_conversions                 lead_conversions[]

  @@index([account_type_id], map: "idx_accounts_account_type_id")
  @@index([branch_id], map: "idx_accounts_branch_id")
}

model activities {
  id                                    BigInt         @id @default(autoincrement())
  activity_type_id                      BigInt
  related_entity_type                   String         @db.VarChar(50)
  related_entity_id                     BigInt
  owner_user_id                         BigInt?
  subject                               String         @db.VarChar(255)
  description                           String?
  activity_at                           DateTime       @db.Timestamptz(6)
  created_by                            BigInt?
  created_at                            DateTime       @default(now()) @db.Timestamptz(6)
  activity_types                        activity_types @relation(fields: [activity_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_activities_created_byTousers    users?         @relation("activities_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  users_activities_owner_user_idTousers users?         @relation("activities_owner_user_idTousers", fields: [owner_user_id], references: [id], onUpdate: NoAction)

  @@index([related_entity_type, related_entity_id], map: "idx_activities_entity")
}

model activity_types {
  id         BigInt       @id @default(autoincrement())
  name       String       @unique @db.VarChar(100)
  activities activities[]
}

model addresses {
  id                BigInt              @id @default(autoincrement())
  line_1            String              @db.VarChar(255)
  line_2            String?             @db.VarChar(255)
  city              String?             @db.VarChar(100)
  state             String?             @db.VarChar(100)
  country           String?             @db.VarChar(100)
  postal_code       String?             @db.VarChar(20)
  account_addresses account_addresses[]
  buildings         buildings[]
  contact_addresses contact_addresses[]
  projects          projects[]
}

model asset_statuses {
  id     BigInt   @id @default(autoincrement())
  name   String   @unique @db.VarChar(100)
  assets assets[]
}

model asset_types {
  id     BigInt   @id @default(autoincrement())
  name   String   @unique @db.VarChar(100)
  assets assets[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model assets {
  id              BigInt         @id @default(autoincrement())
  unit_id         BigInt?
  asset_type_id   BigInt
  asset_status_id BigInt
  asset_code      String?        @unique @db.VarChar(100)
  name            String         @db.VarChar(150)
  brand           String?        @db.VarChar(100)
  model           String?        @db.VarChar(100)
  serial_number   String?        @db.VarChar(100)
  purchase_date   DateTime?      @db.Date
  warranty_expiry DateTime?      @db.Date
  install_date    DateTime?      @db.Date
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  asset_statuses  asset_statuses @relation(fields: [asset_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  asset_types     asset_types    @relation(fields: [asset_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units           units?         @relation(fields: [unit_id], references: [id], onUpdate: NoAction)
  tickets         tickets[]

  @@index([unit_id], map: "idx_assets_unit_id")
}

model attachments {
  id                  BigInt   @id @default(autoincrement())
  related_entity_type String   @db.VarChar(50)
  related_entity_id   BigInt
  file_name           String   @db.VarChar(255)
  file_path           String
  mime_type           String?  @db.VarChar(100)
  file_size           BigInt?
  uploaded_by         BigInt
  uploaded_at         DateTime @default(now()) @db.Timestamptz(6)
  users               users    @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([related_entity_type, related_entity_id], map: "idx_attachments_entity")
}

model audit_logs {
  id          BigInt   @id @default(autoincrement())
  table_name  String   @db.VarChar(100)
  record_id   BigInt
  action_type String   @db.VarChar(50)
  old_data    Json?
  new_data    Json?
  changed_by  BigInt?
  changed_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [changed_by], references: [id], onUpdate: NoAction)

  @@index([table_name, record_id], map: "idx_audit_logs_table_record")
}

model branches {
  id              BigInt        @id @default(autoincrement())
  organization_id BigInt
  name            String        @db.VarChar(150)
  code            String?       @db.VarChar(50)
  address_line_1  String?       @db.VarChar(255)
  address_line_2  String?       @db.VarChar(255)
  city            String?       @db.VarChar(100)
  state           String?       @db.VarChar(100)
  country         String?       @db.VarChar(100)
  postal_code     String?       @db.VarChar(20)
  phone           String?       @db.VarChar(30)
  email           String?       @db.VarChar(150)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  accounts        accounts[]
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  leads           leads[]
  projects        projects[]
  tickets         tickets[]
  users           users[]

  @@unique([organization_id, code], map: "uq_branch_org_code")
  @@index([organization_id], map: "idx_branches_organization_id")
}

model building_types {
  id        BigInt      @id @default(autoincrement())
  name      String      @unique @db.VarChar(100)
  buildings buildings[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model buildings {
  id               BigInt          @id @default(autoincrement())
  project_id       BigInt
  building_type_id BigInt?
  code             String?         @db.VarChar(50)
  name             String          @db.VarChar(150)
  total_floors     Int?
  total_units      Int?
  address_id       BigInt?
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  addresses        addresses?      @relation(fields: [address_id], references: [id], onUpdate: NoAction)
  building_types   building_types? @relation(fields: [building_type_id], references: [id], onUpdate: NoAction)
  projects         projects        @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tickets          tickets[]
  units            units[]

  @@unique([project_id, code], map: "uq_building_project_code")
  @@index([project_id], map: "idx_buildings_project_id")
}

model complaint_sources {
  id      BigInt    @id @default(autoincrement())
  name    String    @unique @db.VarChar(100)
  tickets tickets[]
}

model contact_addresses {
  contact_id   BigInt
  address_id   BigInt
  address_type String    @db.VarChar(50)
  addresses    addresses @relation(fields: [address_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contacts     contacts  @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([contact_id, address_id, address_type])
}

model contact_types {
  id       BigInt     @id @default(autoincrement())
  name     String     @unique @db.VarChar(100)
  contacts contacts[]
}

model contacts {
  id                               BigInt              @id @default(autoincrement())
  account_id                       BigInt?
  contact_type_id                  BigInt
  first_name                       String              @db.VarChar(100)
  last_name                        String?             @db.VarChar(100)
  email                            String?             @db.VarChar(150)
  phone                            String?             @db.VarChar(30)
  mobile                           String?             @db.VarChar(30)
  date_of_birth                    DateTime?           @db.Date
  notes                            String?
  created_by                       BigInt?
  updated_by                       BigInt?
  created_at                       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime            @default(now()) @db.Timestamptz(6)
  contact_addresses                contact_addresses[]
  accounts                         accounts?           @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  contact_types                    contact_types       @relation(fields: [contact_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_contacts_created_byTousers users?              @relation("contacts_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  users_contacts_updated_byTousers users?              @relation("contacts_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  lead_conversions                 lead_conversions[]
  tickets                          tickets[]
  unit_ownerships                  unit_ownerships[]
  unit_tenancies                   unit_tenancies[]

  @@index([account_id], map: "idx_contacts_account_id")
  @@index([contact_type_id], map: "idx_contacts_contact_type_id")
  @@index([email], map: "idx_contacts_email")
}

model escalation_levels {
  id          BigInt        @id @default(autoincrement())
  name        String        @unique @db.VarChar(100)
  level_order Int           @unique
  escalations escalations[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model escalations {
  id                   BigInt            @id @default(autoincrement())
  ticket_id            BigInt
  escalation_level_id  BigInt
  escalated_to_user_id BigInt
  reason               String?           @db.VarChar(255)
  escalated_at         DateTime          @default(now()) @db.Timestamptz(6)
  acknowledged_at      DateTime?         @db.Timestamptz(6)
  users                users             @relation(fields: [escalated_to_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  escalation_levels    escalation_levels @relation(fields: [escalation_level_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets              tickets           @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ticket_id], map: "idx_escalations_ticket_id")
}

model integration_sync_logs {
  id                    BigInt              @id @default(autoincrement())
  integration_system_id BigInt
  entity_type           String              @db.VarChar(50)
  entity_id             BigInt
  operation_type        String              @db.VarChar(50)
  sync_status           String              @db.VarChar(50)
  request_payload       Json?
  response_payload      Json?
  synced_at             DateTime?           @db.Timestamptz(6)
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  integration_systems   integration_systems @relation(fields: [integration_system_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_integration_sync_logs_entity")
}

model integration_systems {
  id                    BigInt                  @id @default(autoincrement())
  name                  String                  @unique @db.VarChar(100)
  system_type           String                  @db.VarChar(100)
  integration_sync_logs integration_sync_logs[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invoice_items {
  id          BigInt   @id @default(autoincrement())
  invoice_id  BigInt
  description String   @db.VarChar(255)
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unit_price  Decimal  @default(0) @db.Decimal(14, 2)
  tax_rate    Decimal  @default(0) @db.Decimal(5, 2)
  line_total  Decimal  @default(0) @db.Decimal(14, 2)
  invoices    invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([invoice_id], map: "idx_invoice_items_invoice_id")
}

model invoice_statuses {
  id       BigInt     @id @default(autoincrement())
  name     String     @unique @db.VarChar(100)
  invoices invoices[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invoices {
  id                 BigInt           @id @default(autoincrement())
  account_id         BigInt
  unit_id            BigInt?
  ticket_id          BigInt?
  invoice_status_id  BigInt
  invoice_number     String           @unique @db.VarChar(100)
  invoice_date       DateTime         @db.Date
  due_date           DateTime         @db.Date
  currency_code      String           @db.Char(3)
  subtotal           Decimal          @default(0) @db.Decimal(14, 2)
  tax_amount         Decimal          @default(0) @db.Decimal(14, 2)
  total_amount       Decimal          @default(0) @db.Decimal(14, 2)
  external_system    String?          @db.VarChar(50)
  external_reference String?          @db.VarChar(100)
  created_by         BigInt?
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @default(now()) @db.Timestamptz(6)
  invoice_items      invoice_items[]
  accounts           accounts         @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users?           @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  invoice_statuses   invoice_statuses @relation(fields: [invoice_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets            tickets?         @relation(fields: [ticket_id], references: [id], onUpdate: NoAction)
  units              units?           @relation(fields: [unit_id], references: [id], onUpdate: NoAction)
  payments           payments[]

  @@index([account_id], map: "idx_invoices_account_id")
  @@index([ticket_id], map: "idx_invoices_ticket_id")
  @@index([unit_id], map: "idx_invoices_unit_id")
}

model lead_conversions {
  id           BigInt    @id @default(autoincrement())
  lead_id      BigInt    @unique
  account_id   BigInt?
  contact_id   BigInt?
  converted_by BigInt
  converted_at DateTime  @default(now()) @db.Timestamptz(6)
  accounts     accounts? @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  contacts     contacts? @relation(fields: [contact_id], references: [id], onUpdate: NoAction)
  users        users     @relation(fields: [converted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads        leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lead_sources {
  id    BigInt  @id @default(autoincrement())
  name  String  @unique @db.VarChar(100)
  leads leads[]
}

model lead_statuses {
  id         BigInt  @id @default(autoincrement())
  name       String  @unique @db.VarChar(100)
  sort_order Int     @default(0)
  leads      leads[]
}

model leads {
  id                                  BigInt            @id @default(autoincrement())
  branch_id                           BigInt?
  lead_source_id                      BigInt?
  lead_status_id                      BigInt
  lifecycle_stage_id                  BigInt
  assigned_user_id                    BigInt?
  first_name                          String            @db.VarChar(100)
  last_name                           String?           @db.VarChar(100)
  company_name                        String?           @db.VarChar(150)
  email                               String?           @db.VarChar(150)
  phone                               String?           @db.VarChar(30)
  budget                              Decimal?          @db.Decimal(14, 2)
  notes                               String?
  created_by                          BigInt?
  updated_by                          BigInt?
  created_at                          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime          @default(now()) @db.Timestamptz(6)
  lead_conversions                    lead_conversions?
  users_leads_assigned_user_idTousers users?            @relation("leads_assigned_user_idTousers", fields: [assigned_user_id], references: [id], onUpdate: NoAction)
  branches                            branches?         @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users_leads_created_byTousers       users?            @relation("leads_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  lead_sources                        lead_sources?     @relation(fields: [lead_source_id], references: [id], onUpdate: NoAction)
  lead_statuses                       lead_statuses     @relation(fields: [lead_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lifecycle_stages                    lifecycle_stages  @relation(fields: [lifecycle_stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_leads_updated_byTousers       users?            @relation("leads_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)

  @@index([assigned_user_id], map: "idx_leads_assigned_user_id")
  @@index([branch_id], map: "idx_leads_branch_id")
  @@index([email], map: "idx_leads_email")
  @@index([lead_source_id], map: "idx_leads_lead_source_id")
  @@index([lead_status_id], map: "idx_leads_lead_status_id")
  @@index([lifecycle_stage_id], map: "idx_leads_lifecycle_stage_id")
}

model lifecycle_stages {
  id         BigInt  @id @default(autoincrement())
  name       String  @unique @db.VarChar(100)
  sort_order Int     @default(0)
  leads      leads[]
}

model notes {
  id                  BigInt   @id @default(autoincrement())
  related_entity_type String   @db.VarChar(50)
  related_entity_id   BigInt
  note_text           String
  created_by          BigInt
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  users               users    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([related_entity_type, related_entity_id], map: "idx_notes_entity")
}

model organizations {
  id         BigInt     @id @default(autoincrement())
  name       String     @db.VarChar(150)
  code       String?    @unique @db.VarChar(50)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at DateTime   @default(now()) @db.Timestamptz(6)
  branches   branches[]
}

model ownership_types {
  id              BigInt            @id @default(autoincrement())
  name            String            @unique @db.VarChar(100)
  unit_ownerships unit_ownerships[]
}

model payment_methods {
  id       BigInt     @id @default(autoincrement())
  name     String     @unique @db.VarChar(100)
  payments payments[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id                 BigInt          @id @default(autoincrement())
  invoice_id         BigInt
  payment_method_id  BigInt
  payment_reference  String?         @db.VarChar(100)
  amount             Decimal         @db.Decimal(14, 2)
  payment_date       DateTime        @default(now()) @db.Timestamptz(6)
  external_system    String?         @db.VarChar(50)
  external_reference String?         @db.VarChar(100)
  recorded_by        BigInt?
  created_at         DateTime        @default(now()) @db.Timestamptz(6)
  invoices           invoices        @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_methods    payment_methods @relation(fields: [payment_method_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users?          @relation(fields: [recorded_by], references: [id], onUpdate: NoAction)

  @@index([invoice_id], map: "idx_payments_invoice_id")
}

model permissions {
  id               BigInt             @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  name             String             @db.VarChar(150)
  module_name      String             @db.VarChar(100)
  role_permissions role_permissions[]
}

model project_statuses {
  id       BigInt     @id @default(autoincrement())
  name     String     @unique @db.VarChar(100)
  projects projects[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model projects {
  id                               BigInt           @id @default(autoincrement())
  branch_id                        BigInt?
  project_status_id                BigInt
  code                             String?          @unique @db.VarChar(50)
  name                             String           @db.VarChar(150)
  description                      String?
  address_id                       BigInt?
  start_date                       DateTime?        @db.Date
  end_date                         DateTime?        @db.Date
  created_by                       BigInt?
  updated_by                       BigInt?
  created_at                       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime         @default(now()) @db.Timestamptz(6)
  buildings                        buildings[]
  addresses                        addresses?       @relation(fields: [address_id], references: [id], onUpdate: NoAction)
  branches                         branches?        @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  users_projects_created_byTousers users?           @relation("projects_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  project_statuses                 project_statuses @relation(fields: [project_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_projects_updated_byTousers users?           @relation("projects_updated_byTousers", fields: [updated_by], references: [id], onUpdate: NoAction)
  tickets                          tickets[]

  @@index([branch_id], map: "idx_projects_branch_id")
  @@index([project_status_id], map: "idx_projects_status_id")
}

model role_permissions {
  role_id       BigInt
  permission_id BigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model roles {
  id               BigInt             @id @default(autoincrement())
  name             String             @unique @db.VarChar(100)
  description      String?            @db.VarChar(255)
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

model sla_policies {
  id               BigInt             @id @default(autoincrement())
  name             String             @unique @db.VarChar(150)
  description      String?            @db.VarChar(255)
  sla_policy_rules sla_policy_rules[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sla_policy_rules {
  id                      BigInt                 @id @default(autoincrement())
  sla_policy_id           BigInt
  ticket_priority_id      BigInt
  ticket_category_id      BigInt?
  response_time_minutes   Int
